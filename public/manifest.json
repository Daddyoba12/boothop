{
  "id": "com.boothop.app",
  "name": "BootHop – Ship Anything. Anywhere.",
  "short_name": "BootHop",
  "description": "Peer-to-peer international delivery with real-time GPS tracking. Connect with verified travellers, track your package live, and pay securely via escrow.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "background_color": "#0a0f1e",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["travel", "shopping", "logistics", "business"],
  "iarc_rating_id": "",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "related_applications": [
    {
      "platform": "play",
      "id": "com.boothop.app",
      "url": "https://play.google.com/store/apps/details?id=com.boothop.app"
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+boothop",
      "url": "/open?target=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 320
  },
  "scope_extensions": [
    { "origin": "https://commander.boothop.com" }
  ],
  "widgets": [
    {
      "name": "Shipment Status",
      "short_name": "Track",
      "description": "Live tracking status for your BootHop delivery",
      "tag": "boothop-tracker",
      "ms_ac_template": "/widgets/tracker.json",
      "data": "/api/dashboard?background=1",
      "type": "application/json",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }],
      "screenshots": [{ "src": "/images/boothop-screenshot-narrow.png", "sizes": "1080x1920" }],
      "auth": true,
      "update": 3600
    }
  ],
  "icons": [
    {
      "src": "/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Send a Package",
      "short_name": "Send",
      "description": "Post a delivery request",
      "url": "/start?role=sender",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "I'm Travelling",
      "short_name": "Travel",
      "description": "Post your trip and earn",
      "url": "/start?role=traveller",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    }
  ],
  "screenshots": [
    {
      "src": "/images/boothop-screenshot-narrow.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "BootHop — Send anything, anywhere"
    },
    {
      "src": "/images/boothop-screenshot-wide.jpg",
      "sizes": "2848x1600",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "BootHop homepage"
    }
  ]
}
